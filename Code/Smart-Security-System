#include <WiFi.h>
#include <Keypad.h>

/* ---------- WIFI ---------- */
const char* ssid = "YOUR_WIFI_NAME";
const char* password = "YOUR_WIFI_PASSWORD";
const char* server = "api.thingspeak.com";
String apiKey = "YOUR_WRITE_API_KEY";

/* ---------- PIN DEFINITIONS ---------- */
#define TOUCH_PIN   23
#define LASER_PIN   4
#define LDR_PIN     34
#define BUZZER_PIN  18
#define LED_PIN     19

/* ---------- KEYPAD ---------- */
const byte ROWS = 4;
const byte COLS = 4;

char keys[ROWS][COLS] = {
  {'1','2','3','A'},
  {'4','5','6','B'},
  {'7','8','9','C'},
  {'*','0','#','D'}
};

byte rowPins[ROWS] = {13, 12, 14, 27};
byte colPins[COLS] = {26, 25, 33, 32};

Keypad keypad = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS);

/* ---------- VARIABLES ---------- */
String correctPIN = "1234";
String enteredPIN = "";

bool authMode = false;
bool authorized = false;
bool alarmOn = false;

unsigned long stateStartTime = 0;
unsigned long lastThingSpeakUpdate = 0;

const unsigned long AUTH_TIME   = 15000;
const unsigned long ALARM_TIME  = 10000;
const unsigned long ACCESS_TIME = 15000;

const int LDR_INTRUSION_LEVEL = 4000;

/* ---------- THINGSPEAK ---------- */
void updateThingSpeak(int ldr, int alert, int state) {

  if (millis() - lastThingSpeakUpdate < 15000) return;

  WiFiClient client;
  if (client.connect(server, 80)) {

    String url = "/update?api_key=" + apiKey +
                 "&field1=" + String(ldr) +
                 "&field2=" + String(alert) +
                 "&field3=" + String(state);

    client.print(String("GET ") + url + " HTTP/1.1\r\n" +
                 "Host: " + server + "\r\n" +
                 "Connection: close\r\n\r\n");

    lastThingSpeakUpdate = millis();
    Serial.println("ThingSpeak Updated");
  }
}

/* ---------- RESET ---------- */
void systemReset() {

  alarmOn = false;
  authMode = false;
  authorized = false;
  enteredPIN = "";

  digitalWrite(BUZZER_PIN, LOW);
  digitalWrite(LED_PIN, LOW);
  digitalWrite(LASER_PIN, HIGH);

  Serial.println("System Reset");
}

/* ---------- SETUP ---------- */
void setup() {

  Serial.begin(9600);

  pinMode(TOUCH_PIN, INPUT);
  pinMode(LASER_PIN, OUTPUT);
  pinMode(BUZZER_PIN, OUTPUT);
  pinMode(LED_PIN, OUTPUT);

  digitalWrite(LASER_PIN, HIGH);

  WiFi.begin(ssid, password);
  Serial.print("Connecting to WiFi");

  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println("\nWiFi Connected");
  Serial.println("Security System Armed");
}

/* ---------- LOOP ---------- */
void loop() {

  int ldrValue = analogRead(LDR_PIN);
  int systemState = 0;
  int alertState = 0;

  /* ---------- ARMED MODE ---------- */
  if (!authorized && !authMode) {

    if (ldrValue > LDR_INTRUSION_LEVEL) {
      alarmOn = true;
      stateStartTime = millis();
      Serial.println("Intrusion Detected");
    }
  }

  /* ---------- TOUCH SENSOR ---------- */
  if (digitalRead(TOUCH_PIN) == HIGH && !authMode && !authorized) {

    authMode = true;
    enteredPIN = "";
    stateStartTime = millis();
    Serial.println("Enter PIN and press #");
  }

  /* ---------- KEYPAD ---------- */
  if (authMode && !authorized) {

    systemState = 1;
    char key = keypad.getKey();

    if (key) {

      if (key == '#') {

        if (enteredPIN == correctPIN) {
          authorized = true;
          authMode = false;
          stateStartTime = millis();
          digitalWrite(LASER_PIN, LOW);
          Serial.println("Access Granted");
        } else {
          alarmOn = true;
          stateStartTime = millis();
          Serial.println("Wrong PIN");
        }

        enteredPIN = "";
      }
      else if (key == '*') {
        enteredPIN = "";
      }
      else {
        enteredPIN += key;
      }
    }

    if (millis() - stateStartTime > AUTH_TIME) {
      systemReset();
    }
  }

  /* ---------- ACCESS MODE ---------- */
  if (authorized) {

    systemState = 2;

    if (millis() - stateStartTime > ACCESS_TIME) {
      systemReset();
    }
  }

  /* ---------- ALARM MODE ---------- */
  if (alarmOn) {

    alertState = 1;
    digitalWrite(BUZZER_PIN, HIGH);
    digitalWrite(LED_PIN, HIGH);

    if (millis() - stateStartTime > ALARM_TIME) {
      systemReset();
    }
  }

  updateThingSpeak(ldrValue, alertState, systemState);

  delay(50);
}
